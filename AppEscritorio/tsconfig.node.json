{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "isolatedModules": true,
    "composite": true,
    "types": ["electron-vite/node"]
  },
  "include": [
    "electron.vite.config.*", 
    "src/main/**/*", 
    "src/preload/**/*"
  ]
}